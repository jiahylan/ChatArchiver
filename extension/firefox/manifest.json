{
  "manifest_version": 2,
  "name": "ChatArchiver",
  "version": "1.0.0",
  "description": "Save AI chat conversations to ChatArchiver",
  "permissions": ["activeTab", "clipboardRead", "clipboardWrite"],
  "browser_specific_settings": {
    "gecko": {
      "id": "chatarchiver@chatarchiver.app",
      "strict_min_version": "109.0"
    }
  },
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": "script-src 'self'; object-src 'self';"
}